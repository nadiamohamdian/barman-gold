{
  "name": "barman-gold",
  "version": "1.0.0",
  "description": "فروشگاه آنلاین طلا و جواهرات لوکس",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "cd apps/api && npm run dev",
    "dev:web": "cd apps/web && npm run dev",
    "build": "npm run build:api && npm run build:web",
    "build:api": "cd apps/api && npm run build",
    "build:web": "cd apps/web && npm run build",
    "start": "concurrently \"npm run start:api\" \"npm run start:web\"",
    "start:api": "cd apps/api && npm run start",
    "start:web": "cd apps/web && npm run start",
    "lint": "npm run lint:api && npm run lint:web",
    "lint:api": "cd apps/api && npm run lint",
    "lint:web": "cd apps/web && npm run lint",
    "type-check": "npm run type-check:api && npm run type-check:web",
    "type-check:api": "cd apps/api && npm run type-check",
    "type-check:web": "cd apps/web && npm run type-check",
    "test": "npm run test:api && npm run test:web",
    "test:api": "cd apps/api && npm run test",
    "test:web": "cd apps/web && npm run test",
    "clean": "npm run clean:api && npm run clean:web",
    "clean:api": "cd apps/api && rm -rf dist node_modules",
    "clean:web": "cd apps/web && rm -rf .next node_modules",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "db:generate": "cd apps/api && npx prisma generate",
    "db:push": "cd apps/api && npx prisma db push",
    "db:migrate": "cd apps/api && npx prisma migrate dev",
    "db:reset": "cd apps/api && npx prisma migrate reset",
    "db:seed": "cd apps/api && npx tsx src/scripts/create-admin.ts",
    "setup": "npm install && npm run db:generate && npm run db:push && npm run db:seed"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "keywords": [
    "ecommerce",
    "jewelry",
    "gold",
    "nextjs",
    "nodejs",
    "typescript",
    "prisma",
    "tailwindcss"
  ],
  "author": "بارمن گلد",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/barman-gold.git"
  },
  "bugs": {
    "url": "https://github.com/your-username/barman-gold/issues"
  },
  "homepage": "https://barman-gold.ir",
  "packageManager": "npm@10"
}
